# Supabase — obtener en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en el servidor (Vercel env vars, no exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Cron job — cualquier string largo y secreto
CRON_SECRET=un-valor-secreto-largo-aqui

# Web Push (generar con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key
VAPID_SUBJECT=mailto:tu@email.com

# Resend (email fallback) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
